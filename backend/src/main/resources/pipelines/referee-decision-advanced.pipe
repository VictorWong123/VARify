{
	"components": [
		{
			"id": "input",
			"provider": "webhook",
			"config": {}
		},
		{
			"id": "evidence_extractor",
			"provider": "llm_gmi_cloud",
			"config": {
				"serverbase": "${GMI_BASE_URL:https://api.gmi-serving.com}",
				"model": "${GMI_MODEL:meta-llama/Llama-3.1-70B-Instruct}",
				"modelTotalTokens": 8000,
				"apikey": "${GMI_API_KEY}",
				"temperature": 0.3,
				"system_prompt": "Extract and summarize key evidence moments from the provided Gemini video analysis JSON. Focus on timestamps, player actions, and potential infractions. Preserve videoIndex and timestampSeconds when present."
			},
			"input": [
				{
					"lane": "text",
					"from": "input"
				}
			]
		},
		{
			"id": "referee_decision",
			"provider": "llm_gmi_cloud",
			"config": {
				"serverbase": "${GMI_BASE_URL:https://api.gmi-serving.com}",
				"model": "${GMI_MODEL:meta-llama/Llama-3.1-70B-Instruct}",
				"modelTotalTokens": 8000,
				"apikey": "${GMI_API_KEY}",
				"temperature": 0.2,
				"system_prompt": "You are a soccer referee decision assistant. Based on the extracted evidence, decide whether the incident is RED_CARD, YELLOW_CARD, or NO_CARD. Apply Law 12 concepts: careless, reckless, excessive force, serious foul play, violent conduct, point of contact, speed, control, chance to play the ball, and player safety. Use only the provided evidence. Do not invent timestamps. Return a single raw JSON object only. Do not use markdown fences or explanatory text. Required fields: decision, confidence, ruleCategory, explanation, keyMoments, evidence. decision must be RED_CARD, YELLOW_CARD, or NO_CARD. confidence must be 0-100. keyMoments and evidence items must include videoIndex, timestampSeconds, and description."
			},
			"input": [
				{
					"lane": "text",
					"from": "evidence_extractor"
				}
			]
		},
		{
			"id": "output",
			"provider": "response_text",
			"config": {},
			"input": [
				{
					"lane": "text",
					"from": "referee_decision"
				}
			]
		}
	],
	"project_id": "c3d4e5f6-a7b8-49ca-d1e2-f3a4b5c6d7e8",
	"viewport": {
		"x": 0,
		"y": 0,
		"zoom": 1
	},
	"version": 1
}
