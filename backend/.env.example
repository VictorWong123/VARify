# Required for live video analysis.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Required for live referee decisions (direct GMI path or RocketRide pipeline LLM steps).
GMI_API_KEY=
GMI_BASE_URL=https://api.gmi-serving.com
GMI_MODEL=

# Optional RocketRide orchestration (set ROCKETRIDE_ENABLED=true to use pipeline for decisions).
ROCKETRIDE_ENABLED=false
ROCKETRIDE_APIKEY=
ROCKETRIDE_URI=https://cloud.rocketride.ai
ROCKETRIDE_PIPELINE=classpath:pipelines/referee-decision-advanced.pipe
ROCKETRIDE_PYTHON=python
ROCKETRIDE_SCRIPT=scripts/run_rocketride_pipeline.py
ROCKETRIDE_TIMEOUT_SECONDS=120
ROCKETRIDE_HEALTH_PING=false
