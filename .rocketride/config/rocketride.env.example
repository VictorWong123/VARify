# RocketRide Configuration
# Copy this file to .env and fill in your actual values

# RocketRide Server Configuration
ROCKETRIDE_URI=https://cloud.rocketride.ai
ROCKETRIDE_APIKEY=your-api-key-here

# Model Provider APIs
GMI_BASE_URL=https://api.gmi-serving.com
GMI_API_KEY=your-gmi-api-key-here
GOOGLE_AI_KEY=your-google-ai-key-here

# Pipeline Input/Output Paths
ROCKETRIDE_INPUT_PATH=/data/input
ROCKETRIDE_OUTPUT_PATH=/data/output

# Project Configuration
ROCKETRIDE_PROJECT_ID=your-project-id-here
