{
	"components": [
		{
			"id": "input",
			"provider": "webhook",
			"config": {}
		},
		{
			"id": "evidence_extractor",
			"provider": "transform",
			"config": {
				"description": "Extract key evidence moments from video metadata"
			},
			"input": [
				{
					"lane": "text",
					"from": "input"
				}
			]
		},
		{
			"id": "video_analyzer",
			"provider": "llm",
			"config": {
				"model": "${GMI_MODEL:meta-llama/Llama-3.1-70B-Instruct}",
				"provider": "gmi-h100",
				"temperature": 0.5,
				"max_tokens": 1500,
				"system_prompt": "Analyze the video evidence moments provided and generate a comprehensive analysis report."
			},
			"input": [
				{
					"lane": "text",
					"from": "evidence_extractor"
				}
			]
		},
		{
			"id": "output",
			"provider": "response_text",
			"config": {},
			"input": [
				{
					"lane": "text",
					"from": "video_analyzer"
				}
			]
		}
	],
	"project_id": "b2c3d4e5-f6a7-48b9-c0d1-e2f3a4b5c6d7",
	"viewport": {
		"x": 0,
		"y": 0,
		"zoom": 1
	},
	"version": 1
}
